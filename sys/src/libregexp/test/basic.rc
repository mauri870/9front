#!/bin/rc

fn fail {
	echo $* >[1=2]
	exit $"*
}

fn M {
	sub=`'('{echo $3}
	if(! match=`'('{./$O.regexec $1 $2 $#sub}) {
		fail 'regexec did not match:' $*
	}
	if(! rmatch=`'('{./$O.rregexec $1 $2 $#sub}) {
		fail 'rregexec did not match:' $*
	}
	if(! ~ $"match $"rmatch) {
		fail 'inconsistent' 'regexec:' $"match 'rregexec:' $"rmatch
	}
	match=$match(1-$#sub)
	if(! ~ $"match $"sub){
		fail 'did not match:' $* '!=' $match
	}
}

